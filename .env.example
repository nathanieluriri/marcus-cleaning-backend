ENV=development
DB_TYPE=mongodb
DB_NAME=marcus_cleaning
MONGO_URL=mongodb://localhost:27017

SECRET_KEY=change-me
SESSION_SECRET_KEY=change-me

GOOGLE_MAPS_API_KEY=change-me
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
SUCCESS_PAGE_URL=http://localhost:8080/success
ERROR_PAGE_URL=http://localhost:8080/error

EMAIL_USERNAME=change-me@example.com
EMAIL_PASSWORD=change-me
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=uploads
# S3_BUCKET_NAME=change-me
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=

PAYMENT_DEFAULT_PROVIDER=test
TEST_PAYMENT_BASE_URL=http://localhost:8000
TEST_PAYMENT_WEBHOOK_SECRET_HASH=change-me
# FLUTTERWAVE_SECRET_KEY=change-me
# FLW_WEBHOOK_SECRET_HASH=change-me
# STRIPE_SECRET_KEY=change-me
# STRIPE_WEBHOOK_SECRET=change-me

ROLE_RATE_LIMITS=anonymous:20/minute,cleaner:80/minute,customer:80/minute,admin:140/minute
BOOKING_ALLOW_ACCEPT_ON_PENDING_PAYMENT=true

# Admin monitoring defaults (safe baseline)
ADMIN_MONITORING_ALERT_WEBHOOK_URL=
ADMIN_MONITORING_ALERT_WEBHOOK_TIMEOUT_SECONDS=3
ADMIN_MONITORING_ALERT_EMAIL_RECIPIENTS=local-admin@example.com
ADMIN_MONITORING_COOLDOWN_INFO_SECONDS=300
ADMIN_MONITORING_COOLDOWN_WARNING_SECONDS=900
ADMIN_MONITORING_COOLDOWN_HIGH_SECONDS=900
ADMIN_MONITORING_COOLDOWN_CRITICAL_SECONDS=300
ADMIN_MONITORING_BRUTEFORCE_WINDOW_SECONDS=300
ADMIN_MONITORING_BRUTEFORCE_THRESHOLD=10
ADMIN_MONITORING_SUSPICIOUS_SUCCESS_WINDOW_SECONDS=1800
ADMIN_MONITORING_SUSPICIOUS_SUCCESS_FAILURE_THRESHOLD=5
ADMIN_MONITORING_CONCURRENT_SESSION_THRESHOLD=5
ADMIN_MONITORING_SESSION_SPIKE_MULTIPLIER=3
ADMIN_MONITORING_LONG_LIVED_SESSION_SECONDS=86400
ADMIN_MONITORING_REFRESH_CHURN_WINDOW_SECONDS=600
ADMIN_MONITORING_REFRESH_CHURN_THRESHOLD=6
ADMIN_MONITORING_REFRESH_FAILURE_WINDOW_SECONDS=900
ADMIN_MONITORING_REFRESH_FAILURE_THRESHOLD=5
ADMIN_MONITORING_IMPOSSIBLE_TRAVEL_MIN_KM=1000
MONITORING_GEO_PROVIDER_URL=
MONITORING_GEO_PROVIDER_KEY=LOCAL_DISABLED
MONITORING_GEO_PROVIDER_TIMEOUT_SECONDS=2

# Auth0 (required for Auth0-only auth flow)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
AUTH0_AUDIENCE=https://api.your-service
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_DB_CONNECTION=Username-Password-Authentication
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
AUTH0_REVOKE_SESSIONS_ENABLED=false
AUTH0_HTTP_TIMEOUT_SECONDS=5
AUTH0_JWKS_CACHE_TTL_SECONDS=300
AUTH_SESSION_MAX_AGE_ADMIN_SECONDS=43200
AUTH_SESSION_MAX_AGE_CLEANER_SECONDS=43200
AUTH_SESSION_MAX_AGE_CUSTOMER_SECONDS=43200
AUTH_SESSION_IDLE_TIMEOUT_ADMIN_SECONDS=7200
AUTH_SESSION_IDLE_TIMEOUT_CLEANER_SECONDS=7200
AUTH_SESSION_IDLE_TIMEOUT_CUSTOMER_SECONDS=7200
